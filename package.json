{
  "name": "superlearn-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:ios": "expo prebuild --platform ios",
    "build:web": "expo export --platform web",
    "build:android": "expo prebuild --platform android && cd android && ./gradlew assembleRelease",
    "build:android:aab": "expo prebuild --platform android && cd android && ./gradlew bundleRelease",
    "build:ios": "eas build --platform ios",
    "electron:dev": "concurrently \"expo start --web\" \"wait-on tcp:8081 && cd electron && npm run dev\"",
    "electron:prebuild": "npm run build:web && rm -rf electron/web-build && cp -r dist electron/web-build",
    "build:mac": "npm run electron:prebuild && cd electron && npm run build:mac",
    "build:windows": "npm run electron:prebuild && cd electron && npm run build:win",
    "electron:start": "cd electron && npm start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "^6.1.2",
    "expo": "~54.0.32",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.10",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.1"
  },
  "private": true
}