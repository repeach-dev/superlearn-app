{
  "name": "superlearn-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "electron:dev": "concurrently \"expo start --web\" \"wait-on tcp:8081 && cd electron && npm run dev\"",
    "electron:prebuild": "npm run build:web && rm -rf electron/web-build && cp -r dist electron/web-build && sed -i '' 's|src=\"/|src=\"./|g' electron/web-build/index.html && sed -i '' 's|href=\"/|href=\"./|g' electron/web-build/index.html",
    "build:mac": "npm run electron:prebuild && cd electron && npm run build:mac",
    "build:windows": "npm run electron:prebuild && cd electron && npm run build:win",
    "electron:start": "cd electron && npm start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "^6.1.2",
    "expo": "~54.0.32",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-web": "^0.21.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.10",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.1"
  },
  "private": true
}